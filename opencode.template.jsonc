{
  "$schema": "https://opencode.ai/config.json",
  "model": "@OPENCODE_AGENT_MODEL@",
  "small_model": "@OPENCODE_AGENT_MODEL@",
  "agent": {
    "build": {
      "description": "Primary coding agent",
      "mode": "primary",
      "model": "@OPENCODE_AGENT_MODEL@"
    },
    "planner": {
      "description": "Expert planning specialist",
      "mode": "subagent",
      "model": "@OPENCODE_AGENT_MODEL@"
    }
  },
  "command": {
    "plan": {
      "description": "Create implementation plan with risk assessment",
      "template": "{file:/home/user/.config/opencode/ecc-upstream/.opencode/commands/plan.md}\n\n$ARGUMENTS"
    },
    "build-fix": {
      "description": "Fix build errors",
      "template": "{file:/home/user/.config/opencode/ecc-upstream/.opencode/commands/build-fix.md}\n\n$ARGUMENTS"
    },
    "code-review": {
      "description": "Review code quality",
      "template": "{file:/home/user/.config/opencode/ecc-upstream/.opencode/commands/code-review.md}\n\n$ARGUMENTS"
    },
    "refactor-clean": {
      "description": "Remove dead code",
      "template": "{file:/home/user/.config/opencode/ecc-upstream/.opencode/commands/refactor-clean.md}\n\n$ARGUMENTS"
    }
  },
  "skills": {
    "paths": [
      "/home/user/git/github/monorepo/skills"
    ]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Authorization": "@CONTEXT7_AUTHORIZATION@"
      },
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-linear"
      ],
      "enabled": true
    },
    "gmail": {
      "type": "local",
      "command": [
        "node",
        "/opt/mcp-servers/gmail.js"
      ],
      "enabled": true
    },
    "calendar": {
      "type": "local",
      "command": [
        "node",
        "/opt/mcp-servers/calendar.js"
      ],
      "enabled": true
    },
    "drive": {
      "type": "local",
      "command": [
        "node",
        "/opt/mcp-servers/drive.js"
      ],
      "enabled": true
    },
    "people": {
      "type": "local",
      "command": [
        "node",
        "/opt/mcp-servers/people.js"
      ],
      "enabled": true
    },
    "maps": {
      "type": "remote",
      "url": "https://mapstools.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "@GOOGLE_MAPS_API_KEY@"
      },
      "enabled": true
    }
  },
  "plugin": [
    "/home/user/.config/opencode/maps-fix-plugin.ts"
  ],
  "permission": {
    "linear_*": "allow",
    "gmail_*": "allow",
    "calendar_*": "allow",
    "drive_*": "allow",
    "people_*": "allow",
    "maps_*": "allow"
  }
}
