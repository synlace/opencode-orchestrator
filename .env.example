# Non-secret configuration for opencode-orchestrator
# Copy to .env.dev or .env.prod and customize as needed

# Linear team UUID for project creation (required for `opencode init`)
LINEAR_TEAM_ID=

# BWS account name for OS keyring lookup (defaults to synlace)
BWS_ACCOUNT=synlace

# Default git branch name (defaults to main)
DEFAULT_BRANCH=main

# Git commit author identity (defaults to opencode)
GIT_USER_NAME=
GIT_USER_EMAIL=
