#!/usr/bin/env bash
# ecc-git-init: Double-repo overlay initializer (Upstream + Custom ECC)
# Private-by-default GitHub repository initialization with symlinked ECC configurations.

set -euo pipefail

# Configurable defaults (override via environment)
BWS_ACCOUNT="${BWS_ACCOUNT:-synlace}"
LINEAR_TEAM_ID="${LINEAR_TEAM_ID:-}"
DEFAULT_BRANCH="${DEFAULT_BRANCH:-main}"

# Load .env files if present (non-secret config)
ORCHESTRATOR_PATH="$HOME/git/github/synlace/opencode-orchestrator"
for env_file in ".env" ".env.prod" "$ORCHESTRATOR_PATH/.env.prod"; do
    if [ -f "$env_file" ]; then
        set -a; source "$env_file"; set +a
    fi
done

# Cleanup trap: remove temp files and clear secrets on failure
cleanup() {
    unset BWS_ACCESS_TOKEN BWS_SERVER_URL 2>/dev/null || true
    rm -f /tmp/ecc-linear-response.json 2>/dev/null || true
}
trap cleanup EXIT

# Ensure ~/.gitconfig exists as a writable file so 'git config --global' succeeds under NixOS/Home Manager
if [ ! -e "$HOME/.gitconfig" ]; then
    touch "$HOME/.gitconfig"
fi

REPO_NAME=""
VISIBILITY="--private" # Default visibility

# Parse arguments in any position
for arg in "$@"; do
  case "$arg" in
    public|--public)
      VISIBILITY="--public"
      ;;
    private|--private)
      VISIBILITY="--private"
      ;;
    -h|--help|help)
      echo "Usage: ecc-git-init <repo-name> [--public|--private]"
      echo "Defaults to private visibility."
      exit 0
      ;;
    *)
      if [ -z "$REPO_NAME" ]; then
        REPO_NAME="$arg"
      else
        echo "❌ Unknown or duplicate argument: $arg"
        exit 1
      fi
      ;;
  esac
done

# Fix dubious ownership for repos created by root (Docker)
if [ "$(id -u)" -ne 0 ] && [ -d ".git" ]; then
    ABS_PATH="$(pwd)"
    SAFE_REPOS="$(git config --global --get-all safe.directory 2>/dev/null || echo "")"
    if ! echo "$SAFE_REPOS" | grep -qF "$ABS_PATH"; then
        git config --global --add safe.directory "$ABS_PATH"
    fi
fi

# Require a repository name, or default to current directory if it is a git repository
if [ -z "$REPO_NAME" ]; then
    if git rev-parse --is-inside-work-tree &>/dev/null; then
        REPO_NAME=$(basename "$PWD")
        echo "📂 Existing Git repository detected. Upgrading in-place: $REPO_NAME"
    else
        echo "❌ Error: Missing repository name and not inside a Git repository."
        echo "Usage: ecc-git-init <repo-name> [--public|--private]"
        echo "Or run 'ecc-git-init' with no arguments inside an existing repository to upgrade it."
        exit 1
    fi
fi

# Try to resolve LINEAR_API_KEY from environment, fallback to Bitwarden Secrets Manager (bws)
RESOLVED_LINEAR_KEY="${LINEAR_API_KEY:-}"

if [ -z "$RESOLVED_LINEAR_KEY" ]; then
    if ! command -v bws &> /dev/null; then
        echo "❌ Error: Bitwarden Secrets Manager CLI ('bws') is not installed or not in PATH."
        exit 1
    fi

    # Determine BWS access token (either from env or lookup via secret-tool)
    LOCAL_BWS_TOKEN="${BWS_ACCESS_TOKEN:-}"
    if [ -z "$LOCAL_BWS_TOKEN" ] && command -v secret-tool &> /dev/null; then
        echo "🔑 Securely querying BWS access token from OS Keyring..."
        LOCAL_BWS_TOKEN=$(secret-tool lookup service bws-token account "$BWS_ACCOUNT" 2>/dev/null || echo "")
    fi

    if [ -z "$LOCAL_BWS_TOKEN" ]; then
        echo "❌ Error: LINEAR_API_KEY or BWS_ACCESS_TOKEN must be set in your environment (or stored in OS Keyring)."
        echo "A Linear project is required for every repository. Please authenticate with Bitwarden Secrets Manager first."
        exit 1
    fi

    # Export temporarily to query bws
    export BWS_ACCESS_TOKEN="$LOCAL_BWS_TOKEN"
    export BWS_SERVER_URL="https://vault.bitwarden.eu"

    echo "🔑 Fetching Linear API key securely from Bitwarden Secrets Manager..."
    RESOLVED_LINEAR_KEY=$(bws secret list | jq -r '.[] | select(.key == "Linear API Key") | .value' 2>/dev/null || echo "")

    # Immediately clean up secret from environment memory of this script session
    unset BWS_ACCESS_TOKEN
    unset BWS_SERVER_URL

    if [ -z "$RESOLVED_LINEAR_KEY" ]; then
        echo "❌ Error: Could not retrieve 'Linear API Key' from Bitwarden Secrets Manager."
        echo "Please verify that your Secrets Manager access token is valid and has Read-Only access to the 'Linear API Key' secret."
        exit 1
    fi
fi

# Validate LINEAR_TEAM_ID is set
if [ -z "$LINEAR_TEAM_ID" ]; then
    echo "❌ Error: LINEAR_TEAM_ID environment variable is required."
    echo "Set it to your Linear team UUID (e.g., export LINEAR_TEAM_ID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx')."
    exit 1
fi

UPSTREAM_DIR="$HOME/.config/opencode/ecc-upstream"
CUSTOM_DIR="$HOME/.config/opencode/ecc-custom"

# 1. Establish Upstream and Custom bases if missing
if [ ! -d "$UPSTREAM_DIR" ]; then
    echo "⬇️ Cloned upstream ECC base..."
    git clone https://github.com/affaan-m/ECC.git "$UPSTREAM_DIR"
    (cd "$UPSTREAM_DIR" && npm install && npm run build:opencode)
fi

echo "🛡️ Installing/updating global git hooks..."
export ECC_GLOBAL_HOOKS_DIR="$HOME/.config/opencode/git-hooks"
mkdir -p "$ECC_GLOBAL_HOOKS_DIR"
# Use local hooks from opencode-orchestrator instead of upstream ECC
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -d "$SCRIPT_DIR/git-hooks" ]; then
    cp "$SCRIPT_DIR/git-hooks/"* "$ECC_GLOBAL_HOOKS_DIR/" 2>/dev/null || true
    chmod +x "$ECC_GLOBAL_HOOKS_DIR/"* 2>/dev/null || true
else
    (cd "$UPSTREAM_DIR" && ./scripts/codex/install-global-git-hooks.sh)
fi

if [ ! -d "$CUSTOM_DIR" ]; then
    echo "🎨 Initializing empty private custom ECC directory..."
    mkdir -p "$CUSTOM_DIR/commands" "$CUSTOM_DIR/prompts/agents" "$CUSTOM_DIR/instructions"
    echo "# Custom Corporate Standards" > "$CUSTOM_DIR/instructions/CORPORATE_STANDARDS.md"
fi

# Determine if we are doing in-place upgrade or creating new directory
IN_PLACE=false
if git rev-parse --is-inside-work-tree &>/dev/null && [ "$(basename "$PWD")" = "$REPO_NAME" ]; then
    IN_PLACE=true
fi

echo "🚀 Initializing: ${REPO_NAME} with ${VISIBILITY} visibility..."

if [ "$IN_PLACE" = "true" ]; then
    echo "🔄 In-place upgrade of existing directory."
else
    mkdir -p "$REPO_NAME"
    cd "$REPO_NAME"
    git init -b "$DEFAULT_BRANCH"
fi

# 2. Install ecc-universal and copy ECC config
echo "📦 Setting up ECC..."
if [ ! -d "$HOME/.config/opencode/node_modules/ecc-universal" ]; then
    echo "  Installing ecc-universal plugin..."
    (cd "$HOME/.config/opencode" && npm install ecc-universal 2>/dev/null || true)
fi

ECC_PKG="$HOME/.config/opencode/node_modules/ecc-universal/.opencode"

# Copy ECC .opencode config (commands, prompts, plugins, instructions)
if [ -d "$ECC_PKG" ]; then
    echo "  Copying ECC config..."
    # Fix ownership if .opencode is owned by root (from container runs)
    if [ "$(stat -c '%U' .opencode 2>/dev/null)" = "root" ]; then
        if command -v sudo &>/dev/null; then
            sudo chown -R "$(id -u):$(id -g)" .opencode 2>/dev/null || true
        else
            echo "⚠️ Warning: sudo not available, cannot fix .opencode ownership."
        fi
    fi
    # Remove old directories and symlinks completely
    rm -rf .opencode/commands .opencode/prompts .opencode/plugins .opencode/tools .opencode/instructions 2>/dev/null || true
    # Copy fresh from ECC package (contents, not the directory itself)
    cp -r "$ECC_PKG/." .opencode/
    # Remove ECC package's opencode.json — the project root's opencode.json is authoritative
    rm -f .opencode/opencode.json 2>/dev/null || true
    # Strip broken agent/subtask frontmatter from command files (skip if already done)
    FRONTMARKER_DONE="$HOME/.config/opencode/.ecc-frontmatter-stripped"
    if [ ! -f "$FRONTMARKER_DONE" ]; then
        for f in .opencode/commands/*.md; do
            [ -f "$f" ] || continue
            awk '/^---$/{if(!in_front){in_front=1;print;next}else{in_front=0;print;next}} in_front&&/^description:/{next} in_front&&/^agent:/{next} in_front{next} 1' "$f" > "$f.tmp" && mv "$f.tmp" "$f"
        done
        touch "$FRONTMARKER_DONE"
    fi

    # Sanitize example placeholder secrets that would trigger pre-commit hooks
    if [ -f ".opencode/instructions/INSTRUCTIONS.md" ]; then
        sed 's/"sk-proj-xxxxx"/"..."/g' .opencode/instructions/INSTRUCTIONS.md > .opencode/instructions/INSTRUCTIONS.md.tmp && \
        mv .opencode/instructions/INSTRUCTIONS.md.tmp .opencode/instructions/INSTRUCTIONS.md
    fi
    if [ -f ".opencode/prompts/agents/security-reviewer.txt" ]; then
        sed 's/"sk-proj-xxxxx"/"..."/g' .opencode/prompts/agents/security-reviewer.txt > .opencode/prompts/agents/security-reviewer.txt.tmp && \
        mv .opencode/prompts/agents/security-reviewer.txt.tmp .opencode/prompts/agents/security-reviewer.txt
    fi
fi

# Copy prompts and commands to project root for {file:...} references
rm -rf commands prompts 2>/dev/null || true
cp -r .opencode/prompts prompts
cp -r .opencode/commands commands

# Ensure copied project-level prompts are also sanitized
if [ -f "prompts/agents/security-reviewer.txt" ]; then
    sed 's/"sk-proj-xxxxx"/"..."/g' prompts/agents/security-reviewer.txt > prompts/agents/security-reviewer.txt.tmp && \
    mv prompts/agents/security-reviewer.txt.tmp prompts/agents/security-reviewer.txt
fi

# Link custom rules/instructions
mkdir -p .opencode/instructions
ln -sf "$(realpath --relative-to=.opencode/instructions "$CUSTOM_DIR/instructions/CORPORATE_STANDARDS.md")" .opencode/instructions/custom-rules.md

# 3. Create opencode.json with full ECC config and OpenRouter models
cat << 'EOF' > opencode.json
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["ecc-universal"],
  "model": "openrouter/xiaomi/mimo-v2.5",
  "small_model": "openrouter/xiaomi/mimo-v2.5",
  "default_agent": "build",
  "instructions": [
    ".opencode/instructions/custom-rules.md"
  ],
  "agent": {
    "build": {
      "description": "Primary coding agent",
      "mode": "primary",
      "model": "openrouter/xiaomi/mimo-v2.5"
    },
    "planner": {
      "description": "Expert planning specialist",
      "mode": "subagent",
      "model": "openrouter/xiaomi/mimo-v2.5"
    }
  },
  "command": {
    "plan": {
      "description": "Create implementation plan",
      "template": "{file:commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner"
    },
    "build-fix": {
      "description": "Fix build errors",
      "template": "{file:commands/build-fix.md}\n\n$ARGUMENTS"
    },
    "code-review": {
      "description": "Review code quality",
      "template": "{file:commands/code-review.md}\n\n$ARGUMENTS"
    },
    "refactor-clean": {
      "description": "Remove dead code",
      "template": "{file:commands/refactor-clean.md}\n\n$ARGUMENTS"
    }
  }
}
EOF

# 4. Generate .gitignore
cat << 'EOF' > .gitignore
.DS_Store
.env
.env.dev
.env.prod
.opencode/dist/
.opencode/node_modules/
EOF

# 4.5 Generate baseline README.md
cat << EOF > README.md
# $REPO_NAME

Initialized with a layered custom ECC harness.

## Quick Start
1. Run \`opencode\` in this folder.

## Environment Management
- \`just dev\` — Run development environment (loads \`.env.dev\`)
- \`just prod\` — Run production environment (loads \`.env.prod\`)
- \`just build\` — Build the Docker image
- \`just deploy <pr-number>\` — Merge PR, rebuild, and restart
EOF

# 4.6 Generate justfile for environment management
cat << 'JUSTFILE' > justfile
# justfile for environment management

# Build the Docker image
build:
    docker build -t app:latest .

# Run development environment (loads .env.dev)
dev:
    @if [ ! -f .env.dev ]; then echo "❌ .env.dev not found"; exit 1; fi
    docker run --rm \
        --name app-dev \
        -i \
        --network host \
        --env-file .env.dev \
        app:latest

# Run production environment (loads .env.prod)
prod:
    @if [ ! -f .env.prod ]; then echo "❌ .env.prod not found"; exit 1; fi
    docker run --rm \
        --name app-prod \
        -i \
        --network host \
        --env-file .env.prod \
        app:latest

# Deploy: merge PR, rebuild, restart
deploy pr:
    gh pr merge {{pr}} --merge && \
    git pull origin main && \
    docker build -t app:latest . && \
    echo "✅ Deployed successfully"

# Stop running containers
stop:
    @docker stop app-dev 2>/dev/null || true
    @docker stop app-prod 2>/dev/null || true

# Show running containers
status:
    @docker ps --filter "name=app-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
JUSTFILE

# 4.7 Linear + BWS Integration
echo "📊 Creating Linear project for $REPO_NAME..."

PROJECT_RESPONSE=$(curl -s -X POST \
  -H "Content-Type: application/json" \
  -H "Authorization: $RESOLVED_LINEAR_KEY" \
  --data '{
    "query": "mutation { projectCreate(input: { name: \"'"$REPO_NAME"'\", teamIds: [\"'"$LINEAR_TEAM_ID"'\"] }) { success project { id url } } }"
  }' \
  https://api.linear.app/graphql)

SUCCESS=$(echo "$PROJECT_RESPONSE" | jq -r '.data.projectCreate.success' 2>/dev/null || echo "false")

if [ "$SUCCESS" != "true" ]; then
    echo "❌ Error: Failed to create Linear project."
    echo "API Response: $PROJECT_RESPONSE"
    exit 1
fi

PROJECT_ID=$(echo "$PROJECT_RESPONSE" | jq -r '.data.projectCreate.project.id')
PROJECT_URL=$(echo "$PROJECT_RESPONSE" | jq -r '.data.projectCreate.project.url')
echo "✓ Created Linear Project: $PROJECT_URL"

# Store project ID for agent to reference when creating tickets
echo "$PROJECT_ID" > .linear-project-id
echo "$PROJECT_URL" >> .linear-project-id

cat << EOF >> README.md

## Project Management
- [Linear Workspace]($PROJECT_URL)
EOF

echo "📋 Bootstrapping default Linear issues..."
ISSUE_RESPONSE=$(curl -s -X POST \
  -H "Content-Type: application/json" \
  -H "Authorization: $RESOLVED_LINEAR_KEY" \
  --data '{
    "query": "mutation { firstIssue: issueCreate(input: { title: \"Scaffold local ECC configurations\", teamId: \"'"$LINEAR_TEAM_ID"'\", projectId: \"'"$PROJECT_ID"'\" }) { success } secondIssue: issueCreate(input: { title: \"Setup initial test suite (TDD)\", teamId: \"'"$LINEAR_TEAM_ID"'\", projectId: \"'"$PROJECT_ID"'\" }) { success } }"
  }' \
  https://api.linear.app/graphql)

ISSUE_SUCCESS=$(echo "$ISSUE_RESPONSE" | jq -r '.data.firstIssue.success, .data.secondIssue.success' 2>/dev/null | grep -c false || true)
if [ "$ISSUE_SUCCESS" -gt 0 ]; then
    echo "⚠️ Warning: Some Linear issues failed to create."
fi

# 5. Create repository on GitHub and Push Baseline
if ! command -v gh &> /dev/null; then
    echo "❌ Error: GitHub CLI ('gh') is not installed."
    exit 1
fi

HAS_ORIGIN=false
if git remote get-url origin &>/dev/null; then
    HAS_ORIGIN=true
fi

if [ "$HAS_ORIGIN" = "true" ]; then
    echo "🐙 Existing GitHub remote origin detected. Skipping repository creation."
else
    echo "🐙 Creating GitHub repository..."
    if ! gh repo create "$REPO_NAME" "$VISIBILITY" --source=. --remote=origin; then
        echo "❌ Error: Failed to create GitHub repository."
        exit 1
    fi

    echo "📤 Pushing baseline to GitHub..."
    gh auth setup-git 2>/dev/null || true
    git add .
    git commit -m "chore: initial commit with layered custom ECC harness"
    git push -u origin "$DEFAULT_BRANCH"
fi

echo "✅ Success! Overlay active."
echo "👉 Run 'opencode' inside the directory to start."
